{
  "manifest_version": 2,
  "name": "ts — tech startpage",
  "version": "1.4.4",
  "description": "Minimal new tab replacement with fuzzy bookmark search, quick links, and IP info. Replaces the new tab page.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "chrome_settings_overrides": {
    "homepage": "index.html"
  },
  "icons": {
    "192": "icons/icon192.png",
    "512": "icons/icon512.png"
  },
  "permissions": [
    "bookmarks",
    "https://api.ipapi.is/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "jahamarsi@gmail.com",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  }
}
